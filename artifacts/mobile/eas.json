{
  "cli": {
    "version": ">= 18.0.6",
    "appVersionSource": "local"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "withoutCredentials": true,
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "apk": {
      "android": {
        "buildType": "apk"
      }
    }
  }
}
