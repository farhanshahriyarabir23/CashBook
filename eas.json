{
  "monorepo": true,
  "cli": {
    "version": ">= 18.0.6",
     "appVersionSource": "remote",
    "requireCommit": false
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "android": {
        "withoutCredentials": true
      }
    },
    "production": {
      "package": "artifacts/mobile",
      "android": {
        "buildType": "apk"
      }
    },
    "apk": {
      "package": "artifacts/mobile",
      "android": {
        "buildType": "apk"
      }
    }
  }
}
